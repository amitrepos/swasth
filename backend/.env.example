# Environment variables for Swasth Health App Backend

# Database Configuration
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/swasth_db

# Security Settings
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Brevo SMTP Configuration (for sending emails)
# Get your SMTP credentials from https://app.brevo.com/
BREVO_SMTP_SERVER=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SENDER_EMAIL=a6124a001@smtp-brevo.com
BREVO_SMTP_PASSWORD=2ZYjKbyp0UsDvhwd
BREVO_SENDER_NAME=Swasth Health App

# OTP Settings
OTP_EXPIRE_MINUTES=10

# Encryption keys — 64-char hex (32 bytes each) for AES-256-GCM.
# Generate each independently with: python -c "import secrets; print(secrets.token_hex(32))"
# ENCRYPTION_KEY      — SPDI (glucose, BP, SpO2, weight, notes)
# PII_ENCRYPTION_KEY  — PII (email, name, phone, medical conditions) + HMAC + OTP hash
ENCRYPTION_KEY=
PII_ENCRYPTION_KEY=

# Application Settings
PROJECT_NAME=Swasth Health App API
VERSION=1.0.0

# Twilio Messaging
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_WEBHOOK_VALIDATE=False
WHATSAPP_SESSION_TTL_MINUTES=10
