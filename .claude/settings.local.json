  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"$TOOL_INPUT\" | grep -q '\\-\\-no-verify' && echo 'BLOCKED: --no-verify is not allowed. Fix the issue instead of skipping hooks.' && exit 1 || true"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(echo \"$TOOL_INPUT\" | jq -r '.file_path // \"\"'); case \"$f\" in */analysis_options.yaml|*/pyproject.toml|*/.coveragerc|*/.github/workflows/*) echo 'WARNING: You are about to modify a config/CI file. Make sure this is intentional and not to weaken checks.' ;; esac; true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"unknown\"' | { read -r f; echo \"  - $(date '+%H:%M:%S') modified: $f\" >> /Users/amitkumarmishra/workspace/swasth/swasth_app/AUDIT.md; } 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "f=$(jq -r '.tool_input.file_path // \"\"'); case \"$f\" in *.dart) dart format \"$f\" 2>/dev/null || true ;; *.py) cd /Users/amitkumarmishra/workspace/swasth/swasth_app/backend && python -m black \"$f\" --quiet 2>/dev/null || true ;; esac"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "P=/Users/amitkumarmishra/workspace/swasth/swasth_app; echo \"## $(date '+%Y-%m-%d %H:%M') — Pre-compact state\" >> $P/.claude/compact-state.md && echo \"Branch: $(git -C $P branch --show-current 2>/dev/null)\" >> $P/.claude/compact-state.md && echo \"Last commit: $(git -C $P log --oneline -1 2>/dev/null)\" >> $P/.claude/compact-state.md && git -C $P diff --stat >> $P/.claude/compact-state.md 2>/dev/null && echo '---' >> $P/.claude/compact-state.md || true"
          }
        ]
      }
    ],
