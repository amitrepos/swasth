{
  "$comment": "Canonical Domain Expert Review Matrix (data-driven, WS2/WS4/WS9). `globs` are Python regexes matched against repo-relative changed-file paths; scripts/compute_required_reviewers.py reads them. .claude/scripts/check-required-reviewers.sh mirrors the same logic for the local pre-commit gate. Daniel is always appended last. Meera is intentionally absent — necessity validation moved to the intake gate (docs/agent-platform/SKILLS_AUDIT.md). mandatory_blocking experts (security, phi) hard-block when required; others block on CRITICAL/Must-Fix per their own gate; daniel is severity-gated.",
  "always_last": "daniel",
  "mandatory_blocking": ["security", "phi"],
  "rules": [
    { "match": "any .dart or .py source", "globs": ["\\.(dart|py)$"], "experts": ["daniel"] },
    { "match": "lib/screens/ | lib/widgets/ | lib/theme/", "globs": ["^lib/(screens|widgets)/", "^lib/theme/"], "experts": ["sunita", "aditya", "doctor", "daniel"] },
    { "match": "lib/l10n/*.arb", "globs": ["^lib/l10n/.*\\.arb$"], "experts": ["sunita", "aditya", "daniel"] },
    { "match": "routes_health.py | health_utils.py | routes_meals.py", "globs": ["^backend/(routes_health|health_utils|routes_meals)\\.py$"], "experts": ["doctor", "phi", "legal", "sunita", "priya", "daniel"] },
    { "match": "ai_service.py", "globs": ["^backend/ai_service\\.py$"], "experts": ["doctor", "legal", "phi", "sunita", "daniel"] },
    { "match": "models.py | schemas.py | backend/migrations/", "globs": ["^backend/(models|schemas)\\.py$", "^backend/migrations/"], "experts": ["legal", "phi", "priya", "daniel"] },
    { "match": "auth.py | dependencies.py | routes.py", "globs": ["^backend/(auth|dependencies|routes)\\.py$"], "experts": ["security", "legal", "daniel"] },
    { "match": "encryption_service.py", "globs": ["^backend/encryption_service\\.py$"], "experts": ["phi", "security", "daniel"] },
    { "match": "routes_doctor.py | lib/screens/doctor_*", "globs": ["^backend/routes_doctor\\.py$", "^lib/screens/doctor_"], "experts": ["doctor", "legal", "daniel"] },
    { "match": "routes_admin.py | admin_dashboard*", "globs": ["^backend/routes_admin\\.py$", "admin_dashboard"], "experts": ["legal", "aditya", "daniel"] },
    { "match": "pubspec.yaml | backend/requirements.txt", "globs": ["^pubspec\\.yaml$", "^backend/requirements\\.txt$"], "experts": ["security", "daniel"] },
    { "match": "backend/tests/*.py | test/*.dart", "globs": ["^backend/tests/.*\\.py$", "^test/.*\\.dart$"], "experts": ["priya", "daniel"] }
  ],
  "intake_gate_personas": {
    "$comment": "Run BEFORE code (Path B intake gate, owned by Priya). Not commit-time markers.",
    "owner": "priya",
    "necessity": ["meera", "sunita", "doctor"]
  },
  "valid_marker_experts": ["sunita", "aditya", "doctor", "daniel", "phi", "legal", "security", "priya"]
}
