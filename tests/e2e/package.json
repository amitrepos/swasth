{
  "name": "swasth-e2e",
  "version": "0.0.1",
  "private": true,
  "description": "Playwright E2E tests for the Swasth health app — runs against the dev server.",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed --workers=1",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0"
  }
}
