# Environment Configuration for Swasth App
# This is an example file - copy to .env and fill in your actual values

# Backend Server Configuration
SERVER_HOST=http://YOUR_IP_ADDRESS:8000
# Example: SERVER_HOST=http://10.0.0.189:8000
# To find your IP: run 'ipconfig' in Command Prompt
# For mobile access, use your computer's IP (not localhost)
