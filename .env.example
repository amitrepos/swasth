# Environment Configuration for Swasth App
# This is an example file - copy to .env and fill in your actual values

# Backend Server Configuration
SERVER_HOST=http://YOUR_IP_ADDRESS:8000
# Example: SERVER_HOST=http://10.0.0.189:8000
# To find your IP: run 'ipconfig' in Command Prompt
# For mobile access, use your computer's IP (not localhost)

# ── JIRA + Anthropic (JIRA Agent Automation) ──────────────────────────
# Required for scripts/jira_*.{sh,py} and the JIRA agent workflows.
# In GitHub Actions these come from repo secrets, NOT this file.
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=
JIRA_PROJECT_KEY=NUO
ANTHROPIC_API_KEY=
# CLAUDE_CODE_OAUTH_TOKEN is set as a GitHub secret only (not local).

# ── Geofence Email Allowlist ──────────────────────────────────────────
# Comma-separated list of emails that bypass the India-only geofence
# (DPDPA/DISHA compliance). Maximum 25 entries. Hashed using
# PII_ENCRYPTION_KEY at startup for secure lookup.
GEOFENCE_EMAIL_ALLOWLIST=smoke@swasth.health,tester@swasth.health
