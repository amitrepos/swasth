  "tosDoctorTitle": "ವೈದ್ಯರೊಂದಿಗೆ ಡೇಟಾ ಹಂಚಿಕೆ",
  "tosDoctor": "ನಿಮ್ಮ ಪ್ರೊಫೈಲ್‌ಗೆ ನೀವು ವೈದ್ಯರನ್ನು ಲಿಂಕ್ ಮಾಡಿದಾಗ, ಆ ವೈದ್ಯರೊಂದಿಗೆ ನಿಮ್ಮ ಆರೋಗ್ಯ ಡೇಟಾವನ್ನು ಹಂಚಿಕೊಳ್ಳಲು ನೀವು ಸಮ್ಮತಿಸುತ್ತೀರಿ. ವೈದ್ಯರು ಅವರೊಂದಿಗೆ ಹಂಚಿಕೊಂಡ ಡೇಟಾವನ್ನು ಹೇಗೆ ಬಳಸುತ್ತಾರೆ ಎಂಬುದಕ್ಕೆ ಸ್ವಸ್ಥ ಜವಾಬ್ದಾರನಲ್ಲ. ಪ್ಲಾಟ್‌ಫಾರ್ಮ್ ಬಳಸುವ ವೈದ್ಯರು ಎನ್‌ಎಂಸಿ ನೈತಿಕ ಮಾರ್ಗಸೂಚಿಗಳ ಅನುಸರಣೆಗೆ ಸ್ವತಂತ್ರವಾಗಿ ಜವಾಬ್ದಾರರಾಗಿರುತ್ತಾರೆ. ನೀವು ಯಾವುದೇ ಸಮಯದಲ್ಲಿ ವೈದ್ಯರ ಪ್ರವೇಶವನ್ನು ಹಿಂಪಡೆಯಬಹುದು.",
  "tosLiabilityTitle": "ಜವಾಬ್ದಾರಿಯ ಮಿತಿ",
  "tosLiability": "ಭಾರತೀಯ ಕಾನೂನಿನಿಂದ ಅನುಮತಿಸಲಾದ ಗರಿಷ್ಠ ಮಿತಿಯವರೆಗೆ, ಸ್ವಸ್ಥ ಮತ್ತು ಅದರ ಸಂಸ್ಥಾಪಕರು, ಉದ್ಯೋಗಿಗಳು ಮತ್ತು ಸೇವಾ ಪೂರೈಕೆದಾರರು ಈ ಅಪ್ಲಿಕೇಶನ್‌ನ ಬಳಕೆಯಿಂದ ಉಂಟಾಗುವ ಯಾವುದೇ ಆರೋಗ್ಯ ಫಲಿತಾಂಶಗಳು, ಕ್ಲಿನಿಕಲ್ ನಿರ್ಧಾರಗಳು ಅಥವಾ ಹಾನಿಗಳಿಗೆ ಜವಾಬ್ದಾರರಾಗಿರುವುದಿಲ್ಲ. ಅಪ್ಲಿಕೇಶನ್ ಅನ್ನು 'ಇದ್ದಂತೆಯೇ' ಒದಗಿಸಲಾಗಿದೆ.",
  "tosTerminationTitle": "ಖಾತೆ ಮುಕ್ತಾಯ",
  "tosTermination": "ಅಪ್ಲಿಕೇಶನ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳಿಂದ ನೀವು ಯಾವುದೇ ಸಮಯದಲ್ಲಿ ನಿಮ್ಮ ಖಾತೆಯನ್ನು ಅಳಿಸಬಹುದು. ನಿಮ್ಮ ಎಲ್ಲಾ ಡೇಟಾವನ್ನು 30 ದಿನಗಳೊಳಗೆ ಶಾಶ್ವತವಾಗಿ ಅಳಿಸಲಾಗುತ್ತದೆ. ಈ ನಿಯಮಗಳನ್ನು ಉಲ್ಲಂಘಿಸುವ ಖಾತೆಗಳನ್ನು ಸ್ವಸ್ಥ ಅಮಾನತುಗೊಳಿಸಬಹುದು.",
  "tosGoverningTitle": "ಆಡಳಿತ ಕಾನೂನು",
  "tosGoverning": "ಈ ನಿಯಮಗಳು ಭಾರತದ ಕಾನೂನುಗಳಿಂದ ನಿಯಂತ್ರಿಸಲ್ಪಡುತ್ತವೆ. ವಿವಾದಗಳು ಭಾರತದ ನವದೆಹಲಿಯ ನ್ಯಾಯಾಲಯಗಳ ವಿಶೇಷ ಅಧಿಕಾರ ವ್ಯಾಪ್ತಿಗೆ ಒಳಪಟ್ಟಿರುತ್ತವೆ. ಈ ನಿಯಮಗಳು ಡಿಜಿಟಲ್ ವೈಯಕ್ತಿಕ ಡೇಟಾ ಸಂರಕ್ಷಣಾ ಕಾಯಿದೆ 2023 (DPDPA) ಗೆ ಅನುಗುಣವಾಗಿರುತ್ತವೆ. ಕೊನೆಯದಾಗಿ ನವೀಕರಿಸಿದ್ದು: ಮೇ 2026.",
