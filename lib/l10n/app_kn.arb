  "ppPurpose": "ನಿಮ್ಮ ಆರೋಗ್ಯ ಡೇಟಾವನ್ನು ಇವುಗಳಿಗಾಗಿ ಬಳಸಲಾಗುತ್ತದೆ: ಪ್ರವೃತ್ತಿಗಳು ಮತ್ತು ಆರೋಗ್ಯ ಸ್ಕೋರ್‌ಗಳನ್ನು ತೋರಿಸಲು, ವೈಯಕ್ತಿಕಗೊಳಿಸಿದ ಆರೋಗ್ಯ ಒಳನೋಟಗಳನ್ನು ರಚಿಸಲು, ನಿಮ್ಮ ಕುಟುಂಬ ಸದಸ್ಯರೊಂದಿಗೆ ಹಂಚಿಕೊಳ್ಳಲು ಮತ್ತು ಚಿಕಿತ್ಸೆಗಾಗಿ ನಿಮ್ಮ ವೈದ್ಯರಿಗೆ ಮಾಹಿತಿ ನೀಡಲು.",
  "ppAiTitle": "ಎಐ ಸಂಸ್ಕರಣೆ",
  "ppAi": "ಆರೋಗ್ಯ ಒಳನೋಟಗಳನ್ನು ರಚಿಸಲು ಸ್ವಸ್ಥ ಮೂರನೇ ವ್ಯಕ್ತಿಯ ಎಐ ಸೇವೆಗಳಾದ Google Gemini ಮತ್ತು DeepSeek ಅನ್ನು ಬಳಸುತ್ತದೆ. ನಿಮ್ಮ ಡೇಟಾದ ಸಾರಾಂಶವನ್ನು (ಸರಾಸರಿ ಮತ್ತು ವ್ಯಾಪ್ತಿಗಳು, ವೈಯಕ್ತಿಕ ರೀಡಿಂಗ್‌ಗಳಲ್ಲ) ಈ ಸೇವೆಗಳಿಗೆ ಕಳುಹಿಸಲಾಗುತ್ತದೆ. ನೀವು ಯಾವುದೇ ಸಮಯದಲ್ಲಿ ಎಐ ಸಂಸ್ಕರಣೆಯಿಂದ ಹೊರಗುಳಿಯಬಹುದು; ಬದಲಿಗೆ ನಿಯಮ ಆಧಾರಿತ ಒಳನೋಟಗಳನ್ನು ಬಳಸಲಾಗುತ್ತದೆ. ಎಲ್ಲಾ ಎಐ-ರಚಿತ ವಿಷಯಗಳು ಕೇವಲ ಮಾಹಿತಿಗಾಗಿ ಮತ್ತು ವೈದ್ಯಕೀಯ ಸಲಹೆಯಲ್ಲ.",
  "ppSharingTitle": "ಡೇಟಾ ಹಂಚಿಕೆ",
  "ppSharing": "ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಇವರೊಂದಿಗೆ ಮಾತ್ರ ಹಂಚಿಕೊಳ್ಳಲಾಗುತ್ತದೆ: ನೀವು ಸ್ಪಷ್ಟವಾಗಿ ಆಹ್ವಾನಿಸುವ ಕುಟುಂಬ ಸದಸ್ಯರು, ನೀವು ಸಮ್ಮತಿಸಿದರೆ ಆರೋಗ್ಯ ಒಳನೋಟಗಳಿಗಾಗಿ ಎಐ ಸೇವೆಗಳು (Google Gemini, DeepSeek), ಮತ್ತು ನೀವು ಆರಿಸಿಕೊಂಡರೆ ನಿಮ್ಮ ವೈದ್ಯರು. ನಾವು ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಜಾಹೀರಾತುದಾರರಿಗೆ ಅಥವಾ ಯಾವುದೇ ಇತರ ಮೂರನೇ ವ್ಯಕ್ತಿಗಳಿಗೆ ಮಾರಾಟ ಮಾಡುವುದಿಲ್ಲ ಅಥವಾ ಹಂಚಿಕೊಳ್ಳುವುದಿಲ್ಲ.",
  "ppSecurityTitle": "ಭದ್ರತಾ ಕ್ರಮಗಳು",
  "ppSecurity": "ನಾವು ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಇವುಗಳೊಂದಿಗೆ ರಕ್ಷಿಸುತ್ತೇವೆ: ಡೇಟಾಬೇಸ್‌ನಲ್ಲಿ ಸಂಗ್ರಹಿಸಲಾದ ಆರೋಗ್ಯ ರೀಡಿಂಗ್‌ಗಳಿಗಾಗಿ AES-256 ಎನ್‌ಕ್ರಿಪ್ಶನ್, ಬಿಕ್ರಿಪ್ಟ್ ಪಾಸ್‌ವರ್ಡ್ ಹ್ಯಾಶಿಂಗ್, ಟೋಕನ್ ಮುಕ್ತಾಯದೊಂದಿಗೆ JWT-ಆಧಾರಿತ ದೃಢೀಕರಣ, ಸಾಗಣೆಯಲ್ಲಿರುವ ಎಲ್ಲಾ ಡೇಟಾಗೆ TLS/HTTPS, ಮತ್ತು ನಿಮ್ಮ ಸಾಧನದಲ್ಲಿ ಎನ್‌ಕ್ರಿಪ್ಟ್ ಮಾಡಲಾದ ಸ್ಥಳೀಯ ಸಂಗ್ರಹಣೆ.",
  "ppRetentionTitle": "ಡೇಟಾ ಉಳಿಸಿಕೊಳ್ಳುವಿಕೆ",
  "ppRetention": "ನಿಮ್ಮ ಖಾತೆಯು ಸಕ್ರಿಯವಾಗಿರುವವರೆಗೆ ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಸಂಗ್ರಹಿಸಲಾಗುತ್ತದೆ. ಅಪ್ಲಿಕೇಶನ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳ ಮೂಲಕ ನೀವು ಯಾವುದೇ ಸಮಯದಲ್ಲಿ ನಿಮ್ಮ ಎಲ್ಲಾ ಡೇಟಾವನ್ನು ಅಳಿಸಲು ವಿನಂತಿಸಬಹುದು. ಖಾತೆ ಅಳಿಸಿದ ನಂತರ, ಎಲ್ಲಾ ರೀಡಿಂಗ್‌ಗಳು, ಪ್ರೊಫೈಲ್‌ಗಳು, ಎಐ ಲಾಗ್‌ಗಳು ಮತ್ತು ವೈಯಕ್ತಿಕ ಮಾಹಿತಿಯನ್ನು ಶಾಶ್ವತವಾಗಿ ತೆಗೆದುಹಾಕಲಾಗುತ್ತದೆ.",
  "ppRightsTitle": "ನಿಮ್ಮ ಹಕ್ಕುಗಳು",
  "ppRights": "ಭಾರತೀಯ ಡೇಟಾ ಸಂರಕ್ಷಣಾ ಕಾನೂನಿನ ಅಡಿಯಲ್ಲಿ (SPDI ನಿಯಮಗಳು 2011 ಮತ್ತು DPDP ಕಾಯಿದೆ 2023), ನೀವು ಈ ಹಕ್ಕುಗಳನ್ನು ಹೊಂದಿದ್ದೀರಿ: ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಪ್ರವೇಶಿಸುವುದು, ತಪ್ಪುಗಳನ್ನು ಸರಿಪಡಿಸುವುದು, ಸಮ್ಮತಿಯನ್ನು ಹಿಂಪಡೆಯುವುದು, ನಿಮ್ಮ ಡೇಟಾವನ್ನು ಅಳಿಸಲು ವಿನಂತಿಸುವುದು ಮತ್ತು ದೂರು ದಾಖಲಿಸುವುದು. ಈ ಹಕ್ಕುಗಳನ್ನು ಚಲಾಯಿಸಲು, ಅಪ್ಲಿಕೇಶನ್ ಸೆಟ್ಟಿಂಗ್‌ಗಳನ್ನು ಬಳಸಿ ಅಥವಾ ನಮ್ಮನ್ನು ಸಂಪರ್ಕಿಸಿ.",
  "ppDoctorSharingTitle": "ವೈದ್ಯರೊಂದಿಗೆ ಡೇಟಾ ಹಂಚಿಕೆ",
