#!/bin/bash
# Pre-push hook: branch hygiene + backend tests + Flutter analysis.
# Any failure aborts the push.
#
# Hygiene gate reads pushed refs from STDIN (per githooks(5)) — the branch
# being pushed is not always the currently checked-out HEAD, e.g.
# `git push origin feature/other` from master. Checking HEAD would
# silently validate the wrong branch and defeat the gate.

set -e

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Portable timeout: falls back to running without a timeout if neither
# GNU `timeout` nor BSD `gtimeout` is available. Degrades to "allow"
# rather than locking the user out.
_with_timeout() {
  local secs="$1"; shift
  if command -v timeout >/dev/null 2>&1; then
    timeout "$secs" "$@"
  elif command -v gtimeout >/dev/null 2>&1; then
    gtimeout "$secs" "$@"
  else
    "$@"
  fi
}

echo "══════════════════════════════════════════════════"
echo "  Pre-push checks"
echo "══════════════════════════════════════════════════"

# ── Gate: branch hygiene ──────────────────────────────────────────────
# Read stdin per githooks(5): <local ref> <local sha> <remote ref> <remote sha>
# Collect the local branch names actually being pushed (skip deletes
# and any non-branch refs like tags).
pushed_branches=()
while read -r local_ref _local_sha _remote_ref _remote_sha; do
  [[ -z "$local_ref" ]] && continue
  # Deletes come through as "(delete)" / all-zero local sha — skip them.
  [[ "$local_ref" == "(delete)" ]] && continue
  case "$local_ref" in
    refs/heads/*) pushed_branches+=("${local_ref#refs/heads/}") ;;
    *) ;;  # tags and other refs — no hygiene check
  esac
done

# Fallback for edge cases where stdin is empty (e.g. running the hook
# manually for testing): fall back to HEAD.
if [[ ${#pushed_branches[@]} -eq 0 ]]; then
  fallback="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo '')"
  if [[ -n "$fallback" && "$fallback" != "HEAD" ]]; then
    pushed_branches+=("$fallback")
  fi
fi

# Only query gh if it's installed and authenticated. All network calls
# are wrapped in _with_timeout so a flaky network can't hang the push.
gh_available=0
if command -v gh >/dev/null 2>&1 && _with_timeout 3 gh auth status >/dev/null 2>&1; then
  gh_available=1
fi

if [[ "$gh_available" -eq 1 ]]; then
  for branch in "${pushed_branches[@]}"; do
    [[ "$branch" == "master" || "$branch" == "HEAD" ]] && continue

    merged_pr="$(_with_timeout 5 gh pr list --state merged --head "$branch" --json number --jq '.[0].number' 2>/dev/null || true)"
    if [[ -n "$merged_pr" && "$merged_pr" != "null" ]]; then
      {
        echo ""
        echo "BLOCKED: branch '$branch' already shipped via merged PR #$merged_pr."
        echo "Pushing more commits here is almost certainly a mistake."
        echo "Recover: git checkout master && git pull && git checkout -b <new-branch>"
      } >&2
      exit 1
    fi

    open_pr="$(_with_timeout 5 gh pr list --state open --head "$branch" --json number --jq '.[0].number' 2>/dev/null || true)"
    if [[ -z "$open_pr" || "$open_pr" == "null" ]]; then
      if [[ -z "${SWASTH_ALLOW_BRANCHLESS_PUSH:-}" ]]; then
        {
          echo ""
          echo "WARNING: branch '$branch' has no open PR."
          echo "Every push should be associated with a PR — that's how reviews and CI run."
          echo ""
          echo "If you intend to open the PR right after this push, rerun with:"
          echo "  SWASTH_ALLOW_BRANCHLESS_PUSH=1 git push <args>"
          echo ""
          echo "Otherwise create the PR first:"
          echo "  gh pr create --fill"
        } >&2
        exit 1
      fi
    fi
  done
fi

# ── Gate: orphan-commit detection ─────────────────────────────────────
# Catches the "branched off a stale feature branch" failure mode that
# bit us twice on 2026-04-18. When PR N is squash-merged, the original
# feature commits stay in local history with OLD SHAs, but master now
# has ONE new commit with the same content and a NEW SHA. If someone
# then branches off the stale branch for PR N+1, their branch inherits
# the old-SHA commits. GitHub can't tell they're content-equivalent
# and reports merge conflicts.
#
# git patch-id --stable computes a SHA-independent ID from the commit's
# diff. If our branch has commits whose patch-id matches a commit
# already on master, we're about to push orphans.
#
# Perf: only compare against the last 100 master commits — enough to
# cover weeks of history without scanning the whole repo log.
fetch_patch_ids() {
  # Read commit SHAs from stdin, emit one patch-id per line.
  while read -r sha; do
    [[ -z "$sha" ]] && continue
    git show "$sha" 2>/dev/null | git patch-id --stable 2>/dev/null | awk '{print $1}'
  done
}

if [[ "$gh_available" -eq 1 || -d "$REPO_ROOT/.git" ]]; then
  # We need origin/master present locally for this check. Fetch quietly
  # with a short timeout so a flaky network doesn't block the push.
  _with_timeout 8 git fetch origin master --quiet 2>/dev/null || true

  for branch in "${pushed_branches[@]}"; do
    [[ "$branch" == "master" || "$branch" == "HEAD" ]] && continue

    # Compare patch-ids of commits being pushed vs recent master commits.
    # `git log origin/master..refs/heads/$branch` = commits on our branch
    # not yet on master.
    branch_ref="refs/heads/$branch"
    if ! git rev-parse --verify --quiet "$branch_ref" >/dev/null; then
      continue  # branch already deleted or remote-only — skip
    fi

    branch_patches="$(git log origin/master.."$branch_ref" --format='%H' 2>/dev/null | fetch_patch_ids | sort -u)"
    if [[ -z "$branch_patches" ]]; then
      continue  # nothing to push on this branch, no orphans possible
    fi

    master_patches="$(git log origin/master -n 100 --format='%H' 2>/dev/null | fetch_patch_ids | sort -u)"

    # Intersection = patch-ids present on BOTH master and branch = orphans.
    orphans="$(comm -12 <(echo "$branch_patches") <(echo "$master_patches"))"
    orphan_count="$(echo "$orphans" | grep -c . || true)"

    if [[ "$orphan_count" -gt 0 ]]; then
      {
        echo ""
        echo "BLOCKED: branch '$branch' contains $orphan_count commit(s) whose"
        echo "content is already on master (under different SHAs — squash-merge)."
        echo ""
        echo "This is the 'orphan-commit' failure mode documented in"
        echo ".claude/scripts/scb.sh. Pushing would likely produce a"
        echo "conflicting PR that can't be merged."
        echo ""
        echo "Recover — rebuild the branch cleanly from fresh master:"
        echo ""
        echo "  # 1. identify the ONE commit you actually want to ship"
        echo "  git log origin/master..HEAD --oneline"
        echo "  # 2. rebuild from master and cherry-pick just that commit"
        echo "  git stash push -u -m 'wip'"
        echo "  git scb $branch-v2   # or: checkout master; pull; checkout -b"
        echo "  git cherry-pick <sha-of-the-real-commit>"
        echo ""
        echo "To bypass (you're certain this is fine): SWASTH_ALLOW_ORPHAN_PUSH=1 git push ..."
      } >&2
      if [[ -z "${SWASTH_ALLOW_ORPHAN_PUSH:-}" ]]; then
        exit 1
      fi
      echo "[orphan-check] SWASTH_ALLOW_ORPHAN_PUSH=1 — bypassed" >&2
    fi
  done
fi

# ── Backend pytest ────────────────────────────────────────────────────────
echo ""
echo "▶ Running backend tests..."
export TESTING=true
cd "$REPO_ROOT/backend"
if [ -d "venv" ]; then
    source venv/bin/activate
fi
python -m pytest tests/ --tb=short -q --cov=. --cov-config=.coveragerc
echo "✓ Backend tests passed (85% coverage gate passed)"

# ── Flutter analyze ───────────────────────────────────────────────────────
echo ""
echo "▶ Running Flutter analysis..."
cd "$REPO_ROOT"
flutter analyze --no-fatal-infos --no-fatal-warnings
echo "✓ Flutter analysis passed"

# ── Flutter tests ─────────────────────────────────────────────────────────
echo ""
echo "▶ Running Flutter tests..."
flutter test
echo "✓ Flutter tests passed"

echo ""
echo "══════════════════════════════════════════════════"
echo "  All checks passed — pushing"
echo "══════════════════════════════════════════════════"
